cube = lambda x: x**3 # complete the lambda function 

def fibonacci(n):
    # return a list of fibonacci numbers
    Is = []
    for i in range(n):
        if i == 0:
            Is.append(0)
        elif i == 1:
            Is.append(1)
        else:
            res = Is[i-2] + Is[i-1]
            Is.append(res)
    return Is   

if __name__ == '__main__':
    n = int(input())
    print(list(map(cube, fibonacci(n))))
