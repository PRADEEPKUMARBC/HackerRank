def merge_the_tools(s, k):
    start = 0
    end = k

    while end <= len(s):
        temp = s[start:end]

        result = ""
        for ch in temp:
            if ch not in result:
                result += ch

        print(result)

        start += k
        end += k

if __name__ == '__main__':
    string, k = input(), int(input())
    merge_the_tools(string, k)
